# デフォルト: テキストは自動判定してLFに正規化
* text=auto eol=lf

# Windowsスクリプト
*.bat text eol=crlf
*.cmd text eol=crlf

# 画像
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary

# 動画
*.mp4  binary
*.webm binary
*.mov  binary

# 音声
*.mp3  binary
*.wav  binary
*.ogg  binary
*.m4a  binary

# フォント
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# ドキュメント/アーカイブ/バイナリ
*.pdf  binary
*.zip  binary
*.wasm binary
*.db   binary

# Office
*.xlsx binary
*.xlsm binary
*.docx binary
*.pptx binary

# SVGはテキストとして差分を管理
*.svg text eol=lf

# ロックファイルは統計から除外（差分は残る）
package-lock.json linguist-generated=true
yarn.lock         linguist-generated=true
pnpm-lock.yaml    linguist-generated=true

# ミニファイ済みファイルは統計・差分から除外
*.min.js  -diff linguist-generated=true
*.min.css -diff linguist-generated=true